<!DOCTYPE html>
<html lang="tr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kullanım Sözleşmesi İmza</title>
  <style>
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f8fafc;
      color: #1e293b;
      line-height: 1.6;
    }

    .wrap {
      max-width: 800px;
      margin: 40px auto;
      padding: 0 20px 40px;
    }

    .card {
      background: #fff;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 16px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
      overflow: hidden;
    }

    .head {
      padding: 32px;
      border-bottom: 1px solid #f1f5f9;
      background: linear-gradient(to bottom right, #f8fafc, #ffffff);
      text-align: center;
    }

    .head h1 {
      margin: 0;
      font-size: 24px;
      font-weight: 800;
      color: #0f172a;
      letter-spacing: -0.025em;
    }

    .meta {
      margin-top: 12px;
      color: #64748b;
      font-size: 14px;
      display: flex;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .meta strong {
      color: #334155;
    }

    .body {
      padding: 32px;
    }

    .status {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #166534;
      border-radius: 12px;
      padding: 12px 16px;
      margin-bottom: 24px;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .error {
      background: #fef2f2;
      border: 1px solid #fee2e2;
      color: #991b1b;
      border-radius: 12px;
      padding: 12px 16px;
      margin-bottom: 24px;
      font-size: 14px;
      display: none;
    }

    .agreement-container {
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      background: #ffffff;
      padding: 24px;
      max-height: 400px;
      overflow-y: auto;
      margin-bottom: 24px;
    }

    .agreement {
      white-space: pre-wrap;
      font-size: 14px;
      color: #334155;
    }

    /* Section Highlighting */
    .agreement strong {
      color: #0f172a;
      display: block;
      margin-top: 16px;
      font-size: 15px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 24px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .field label {
      font-size: 14px;
      color: #475569;
      font-weight: 600;
    }

    .field input {
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 15px;
      transition: all 0.2s;
      background: #f8fafc;
    }

    .field input:focus {
      border-color: #3b82f6;
      background: #fff;
      box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
      outline: none;
    }

    .checks {
      display: flex;
      flex-direction: column;
      gap: 12px;
      font-size: 14px;
      color: #475569;
      margin-bottom: 32px;
    }

    .checks label {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      cursor: pointer;
      padding: 8px;
      border-radius: 8px;
      transition: background 0.2s;
    }

    .checks label:hover {
      background: #f1f5f9;
    }

    .checks input[type="checkbox"] {
      margin-top: 4px;
      width: 18px;
      height: 18px;
      cursor: pointer;
    }

    .form-footer {
      display: flex;
      flex-direction: column;
      gap: 16px;
      align-items: center;
      padding-top: 24px;
      border-top: 1px solid #f1f5f9;
    }

    .hint {
      color: #94a3b8;
      font-size: 12px;
      text-align: center;
    }

    .btn-submit {
      width: 100%;
      border: 0;
      background: #0f172a;
      color: #fff;
      border-radius: 10px;
      padding: 14px 24px;
      cursor: pointer;
      font-size: 16px;
      font-weight: 700;
      transition: all 0.2s;
      box-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.2);
    }

    .btn-submit:hover {
      background: #1e293b;
      transform: translateY(-1px);
    }

    .btn-submit:active {
      transform: translateY(0);
    }

    .btn-submit:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    @media (max-width: 820px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="card">
      <div class="head">
        <h1>
          <%= agreementTitle %>
        </h1>
        <div class="meta">
          Kullanıcı: <strong>
            <%= username %>
          </strong> | Rol: <strong>
            <%= role %>
          </strong> | Sürüm: <strong>
            <%= agreementVersion %>
          </strong>
        </div>
      </div>
      <div class="body">
        <% if (existing && existing.signedAt && existing.version===agreementVersion) { %>
          <div class="status">
            Bu sürüm daha önce imzalanmış. İmza Tarihi: <strong>
              <%= new Date(existing.signedAt).toLocaleString('tr-TR') %>
            </strong>
          </div>
          <% } %>

            <div id="error-box" class="error"></div>

            <div class="agreement">
              <%= agreementText %>
            </div>

            <div class="grid">
              <div class="field">
                <label for="full-name">Ad Soyad</label>
                <input id="full-name" type="text" maxlength="120"
                  value="<%= existing && existing.fullName ? existing.fullName : '' %>" placeholder="Ad Soyad" />
              </div>
            </div>

            <div class="checks">
              <label><input type="checkbox" id="confirm-legal" /> Metni okudum, anladım ve tüm maddeleri kabul
                ediyorum.</label>
              <label><input type="checkbox" id="confirm-fraud" /> Dolandırıcılık, sahte mesaj ve aldatıcı içerik
                göndermeyeceğimi beyan ederim.</label>
            </div>

            <div class="footer">
              <div class="hint">Onay sonrası sözleşme PDF olarak üretilir ve yönetici panelinde saklanır.</div>
              <button id="btn-submit" class="btn-submit">Sözleşmeyi Onayla ve Devam Et</button>
            </div>
      </div>
    </div>
  </div>

  <script>
    const nextPath = <% - JSON.stringify(nextPath || '/admin') %>;
    const submitBtn = document.getElementById('btn-submit');
    const errorBox = document.getElementById('error-box');

    function showError(message) {
      errorBox.style.display = 'block';
      errorBox.textContent = message;
    }

    function clearError() {
      errorBox.style.display = 'none';
      errorBox.textContent = '';
    }

    submitBtn.addEventListener('click', async () => {
      clearError();
      const fullName = document.getElementById('full-name').value.trim();
      const confirmLegal = document.getElementById('confirm-legal').checked;
      const confirmFraud = document.getElementById('confirm-fraud').checked;

      if (fullName.length < 5) {
        showError('Lütfen geçerli bir ad soyad girin.');
        return;
      }
      if (!confirmLegal || !confirmFraud) {
        showError('Devam etmek için onay kutularını işaretleyin.');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Onaylanıyor...';

      try {
        const payload = {
          fullName,
          accepted: true,
          nextPath
        };
        const response = await fetch('/legal/agreement/sign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await response.json();
        if (!response.ok) {
          throw new Error(data.error || 'Onay kaydedilemedi.');
        }
        window.location.href = data.redirect || nextPath || '/admin';
      } catch (error) {
        showError(error.message || 'Onay işlemi başarısız.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Sözleşmeyi Onayla ve Devam Et';
      }
    });
  </script>
</body>

</html>